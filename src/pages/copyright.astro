---
import Layout from '../layouts/Layout.astro'
import { COPYRIGHT } from '../lib/copyright'
---

<Layout title="Copyright — People's Poems">
  <div class="page copyright-page">

    <div class="intro">
      <p>The rules of copyright are a mess. Each poem on this site is, to the best of our knowledge, in the public domain. Very old poems are easy. The copyright status of later poems is more difficult to determine. Generally, we follow the guidance set out by <a href="https://guides.library.cornell.edu/copyright/publicdomain">Cornell</a> to determine if a work is in the public domain. What follows is the list of copyright classifications used by <em>People&#8217;s Poems</em>.</p>
      <p class="attribution">&mdash; <a class="initials-link" href="/about#jv">JV</a></p>
    </div>

    <dl class="status-list">
      {Object.entries(COPYRIGHT).filter(([, info]) => !info.hidden).map(([key, { label, description }]) => (
        <div class="status" id={key}>
          <dt><a href={`#${key}`}>{label}</a></dt>
          <dd>{description}</dd>
        </div>
      ))}
    </dl>

  </div>
</Layout>

<style>
  .copyright-page {
    max-width: 640px;
    padding-top: 3.5rem;
    padding-bottom: 6rem;
  }

  .intro {
    margin-bottom: 3rem;
  }

  .intro p {
    font-size: 0.875rem;
    line-height: 1.85;
    color: #555;
  }

  .intro p + p {
    margin-top: 1rem;
  }

  .intro a {
    color: inherit;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    text-decoration-color: #bbb;
  }

  .intro a:hover {
    text-decoration-color: #888;
  }

  .intro .attribution {
    text-align: right;
    margin-top: 0.5rem;
    color: #999;
  }

  .status-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .status dt {
    font-size: 0.8rem;
    font-weight: normal;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #888;
    margin-bottom: 0.35rem;
  }

  .status dt a {
    color: inherit;
    text-decoration: none;
  }

  .status dt a:hover {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .status dd {
    font-size: 0.875rem;
    line-height: 1.75;
    color: #444;
    margin: 0;
  }
</style>
