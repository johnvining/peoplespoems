---
import Layout from '../layouts/Layout.astro'
import { safeFetch } from '../lib/sanity'
import type { Poem } from '../lib/sanity'
import { firstLine } from '../lib/utils'

const allPoems = await safeFetch<Pick<Poem, '_id' | 'number' | 'title' | 'author' | 'source' | 'sourceNotItalic' | 'yearPublished' | 'dateAdded' | 'slug' | 'body'>>(`
  *[_type == "poem" && defined(slug.current)] | order(dateAdded desc) [0...20] {
    _id, number, title, author, source, sourceNotItalic, yearPublished, dateAdded, slug, body
  }
`)
const poems = allPoems.slice(0, 20)

function fmtDate(d: string) {
  return new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
}
---

<Layout title="People's Poems">
  <div class="page home-page">
    <div class="columns">

      <div class="intro">
        <p>Coming soon.</p>
      </div>

      <ul class="poem-list">
        {poems.length === 0 && <li class="empty">No poems yet.</li>}
        {poems.map((poem) => {
          const href = `/${String(poem.number).padStart(5, '0')}/${poem.slug.current}`
          const datePart = poem.dateAdded ? `added ${fmtDate(poem.dateAdded)}` : null
          const sourcePart = [poem.source, poem.yearPublished].filter(Boolean).join(', ') || null
          return (
            <li>
              <a href={href}>
                <div class="primary">
                  {poem.author && <span class="author">{poem.author},&nbsp;</span>}
                  {poem.title
                    ? <span class="title">&ldquo;{poem.title}&rdquo;</span>
                    : <span class="title title--untitled">[{firstLine(poem.body)}]</span>
                  }
                </div>
                {(datePart || sourcePart) && (
                  <div class="secondary">
                    {datePart}
                    {datePart && sourcePart && ' · '}
                    {sourcePart && (
                      <span class={poem.sourceNotItalic ? '' : 'source-italic'}>{sourcePart}</span>
                    )}
                  </div>
                )}
              </a>
            </li>
          )
        })}
      </ul>

    </div>
  </div>
</Layout>

<style>
  .home-page {
    padding-top: 3.5rem;
    padding-bottom: 6rem;
  }

  .columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .intro p {
    font-size: 0.975rem;
    line-height: 1.85;
    color: #555;
  }

  .poem-list {
    list-style: none;
  }

  .poem-list li + li {
    border-top: 1px solid #e8e5df;
  }

  .poem-list li:first-child a {
    padding-top: 0;
  }

  .poem-list a {
    display: block;
    padding: 0.9rem 0;
    text-decoration: none;
    color: inherit;
  }

  .poem-list a:hover .title {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .primary {
    font-size: 0.975rem;
    line-height: 1.5;
  }

  .author { font-weight: normal; }

  .title { font-style: normal; }

  .source-italic { font-style: italic; }

  .secondary {
    margin-top: 0.15rem;
    font-size: 0.72rem;
    color: #c8c4bc;
    line-height: 1.4;
  }

  .empty {
    color: #999;
    font-style: italic;
    font-size: 0.9rem;
  }

  @media (max-width: 700px) {
    .columns {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
