---
import Layout from '../../layouts/Layout.astro'
import { safeFetch } from '../../lib/sanity'
import type { Poem } from '../../lib/sanity'
import { firstLine, fmtDate } from '../../lib/utils'
import { marked } from 'marked'
import { COPYRIGHT } from '../../lib/copyright'

export async function getStaticPaths() {
  const poems = await safeFetch<Pick<Poem, 'number' | 'slug'>>(`
    *[_type == "poem" && defined(slug.current)] { number, slug }
  `)
  return poems.flatMap((poem) => [
    { params: { number: String(poem.number).padStart(5, '0'), slug: undefined } },
    { params: { number: String(poem.number).padStart(5, '0'), slug: poem.slug.current } },
    { params: { number: String(poem.number), slug: undefined } },
    { params: { number: String(poem.number), slug: poem.slug.current } },
  ])
}

const { number } = Astro.params

const all = await safeFetch<Poem>(`
  *[_type == "poem"] {
    _id, _createdAt, number, title, body, author, source, sourceUrlPublic, cityState, sourceNotItalic, yearPublished, datePublished, copyrightStatus, context, dateAdded, slug,
    editor->{ name, initials, email }
  }
`)
const poem = all.find((p) => String(p.number).padStart(5, '0') === number || String(p.number) === number)

if (!poem) return Astro.redirect('/')

if (!Astro.params.slug) {
  return Astro.redirect(`/${number}/${poem.slug.current}`, 301)
}

const dateFormatted = fmtDate(poem.dateAdded ?? poem._createdAt)

const isLong = poem.body.split('\n').length > 20

const pubDate = poem.datePublished
  ? fmtDate(poem.datePublished)
  : poem.yearPublished ?? null

const sourceExtra = [poem.cityState, pubDate != null ? String(pubDate) : null].filter(Boolean).join(', ')
---

<Layout
  title={`${poem.title ?? `[${firstLine(poem.body)}]`} — People's Poems`}
  ogImage={`/og/${String(poem.number).padStart(5, '0')}.png`}
>
  <div class="page poem-page">
    <article>
      <h1>
        {poem.author && <span class="author">{poem.author},&nbsp;</span>}
        {poem.title
          ? <span class="title-text">&ldquo;{poem.title}&rdquo;</span>
          : <span class="title-text title-text--untitled">[{firstLine(poem.body)}]</span>
        }
      </h1>
      <div class="header-gap">
        {(poem.source || sourceExtra) && (
          <div class="source-line">{poem.source && <span class={poem.sourceNotItalic ? '' : 'source-italic'}>{poem.source}</span>}{sourceExtra && (poem.source ? `, ${sourceExtra}` : sourceExtra)}</div>
        )}
      </div>

      <div class={`poem-body${isLong ? ' poem-body--long' : ''}`}>{poem.body}</div>

      {(dateFormatted || poem.context || poem.sourceUrlPublic || poem.source) && (
        <footer class="editorial">
          <p>
            {dateFormatted && <span>Added {dateFormatted}.</span>}
            {poem.sourceUrlPublic && <span> <a class="source-footer-link" href={poem.sourceUrlPublic} target="_blank" rel="noopener noreferrer">View this poem at source.</a></span>}
            {poem.context && <span class="context" set:html={marked.parseInline(poem.context)} />}
            {poem.editor?.initials && <span class="initials"> &mdash; <a class="initials-link" href={`/about#${poem.editor.initials.toLowerCase()}`}>{poem.editor.initials}</a></span>}
          </p>
        </footer>
      )}

      <div class="poem-footer">
        <span class="poem-id">{String(poem.number).padStart(5, '0')}</span>
        {poem.copyrightStatus && COPYRIGHT[poem.copyrightStatus] && (
          <a
            class="copyright-link"
            href={`/copyright#${poem.copyrightStatus}`}
            data-tooltip={COPYRIGHT[poem.copyrightStatus].description}
          >
            {COPYRIGHT[poem.copyrightStatus].label}
          </a>
        )}
        <button
          class="copy-image-btn"
          data-image-url={`/og/${String(poem.number).padStart(5, '0')}.png`}
          aria-label="Copy image to clipboard"
        >Copy as Image</button>
      </div>
    </article>
  </div>
</Layout>

<style>
  .poem-page {
    max-width: 740px;
  }

  h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: normal;
    font-size: 1.6rem;
    font-weight: 400;
    line-height: 1.4;
    margin-bottom: 0.3rem;
  }

  .author, .title-text {
    font-style: normal;
  }

  .title-text--untitled {
    color: #888;
  }

  .header-gap {
    margin-bottom: 3rem;
  }

  .source-line {
    margin-top: 0.3rem;
    font-size: 0.875rem;
    color: #aaa;
  }

  .source-italic { font-style: italic; }

  .source-footer-link {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: #ccc;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
  }

  .source-footer-link:hover {
    color: #888;
  }

  .poem-body {
    font-size: 1.1rem;
    line-height: 1.75;
    white-space: pre-wrap;
  }

  .poem-body--long {
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .editorial {
    margin-top: 3.5rem;
    padding-top: 1.75rem;
    border-top: 1px solid #ddd8ce;
    font-size: 0.82rem;
    color: #aaa;
    line-height: 1.7;
  }

  .initials {
    color: #bbb;
  }

  .initials-link {
    color: inherit;
    text-decoration: none;
  }

  .initials-link:hover {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }


  .poem-footer {
    margin-top: 3rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.25rem;
  }

  .poem-id {
    font-family: monospace;
    font-size: 0.65rem;
    color: #bbb;
    letter-spacing: 0.05em;
  }

  .copyright-link {
    position: relative;
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #ccc;
    text-decoration: none;
  }

  .copyright-link:hover {
    color: #999;
  }

  .copyright-link::after {
    content: attr(data-tooltip);
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    width: 240px;
    background: #333;
    color: #eee;
    font-size: 0.72rem;
    line-height: 1.5;
    letter-spacing: 0;
    text-transform: none;
    padding: 0.5rem 0.75rem;
    border-radius: 3px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s;
    white-space: normal;
  }

  .copyright-link:hover::after {
    opacity: 1;
  }

  .copy-image-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 0.65rem;
    color: #ccc;
  }

  .copy-image-btn:hover {
    color: #999;
  }

  @media (max-width: 600px) {
    h1 {
      font-size: 1.3rem;
    }

    .header-gap {
      margin-bottom: 2rem;
    }

    .poem-body {
      font-size: 1rem;
      line-height: 1.7;
    }

    .poem-body--long {
      font-size: 0.875rem;
    }

    .editorial {
      margin-top: 2.5rem;
      padding-top: 1.25rem;
    }

    .poem-footer {
      margin-top: 2rem;
    }
  }
</style>

<script>
  const btn = document.querySelector<HTMLButtonElement>('.copy-image-btn')
  if (btn) {
    btn.addEventListener('click', async () => {
      const url = btn.dataset.imageUrl!
      try {
        const res  = await fetch(url)
        const blob = await res.blob()
        await navigator.clipboard.write([new ClipboardItem({ 'image/png': blob })])
        btn.textContent = 'Copied!'
        setTimeout(() => { btn.textContent = 'Copy as Image' }, 2000)
      } catch {
        window.open(url, '_blank')
      }
    })
  }
</script>
