---
import Layout from '../../layouts/Layout.astro'
import { safeFetch } from '../../lib/sanity'
import type { Poem } from '../../lib/sanity'
import { firstLine } from '../../lib/utils'

export async function getStaticPaths() {
  const poems = await safeFetch<Pick<Poem, 'number' | 'slug'>>(`
    *[_type == "poem" && defined(slug.current)] { number, slug }
  `)
  return poems.flatMap((poem) => [
    { params: { number: String(poem.number).padStart(5, '0'), slug: undefined } },
    { params: { number: String(poem.number).padStart(5, '0'), slug: poem.slug.current } },
    { params: { number: String(poem.number), slug: undefined } },
    { params: { number: String(poem.number), slug: poem.slug.current } },
  ])
}

const { number } = Astro.params

const all = await safeFetch<Poem>(`
  *[_type == "poem"] {
    _id, number, title, body, author, source, sourceUrl, cityState, sourceNotItalic, yearPublished, datePublished, copyrightStatus, context, dateAdded, slug,
    editor->{ name, initials, email }
  }
`)
const poem = all.find((p) => String(p.number).padStart(5, '0') === number || String(p.number) === number)

if (!poem) return Astro.redirect('/')

if (!Astro.params.slug) {
  return Astro.redirect(`/${number}/${poem.slug.current}`, 301)
}

const dateFormatted = poem.dateAdded
  ? new Date(poem.dateAdded).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null

const isLong = poem.body.split('\n').length > 20

const pubDate = poem.datePublished
  ? new Date(poem.datePublished).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : poem.yearPublished ?? null
---

<Layout title={`${poem.title ?? `[${firstLine(poem.body)}]`} — People's Poems`}>
  <div class="page poem-page">
    <article>
      <h1>
        {poem.author && <span class="author">{poem.author},&nbsp;</span>}
        {poem.title
          ? <span class="title-text">&ldquo;{poem.title}&rdquo;</span>
          : <span class="title-text title-text--untitled">[{firstLine(poem.body)}]</span>
        }
      </h1>
      <div class="header-gap">
        {(poem.source || poem.cityState || pubDate) && (
          <div class="source-line">
            {poem.source && <span class={poem.sourceNotItalic ? '' : 'source-italic'}>{poem.source}</span>}
            {poem.cityState && <span>{poem.source ? `, ${poem.cityState}` : poem.cityState}</span>}
            {pubDate && <span>{(poem.source || poem.cityState) ? `, ${pubDate}` : pubDate}</span>}
          </div>
        )}
      </div>

      <div class={`poem-body${isLong ? ' poem-body--long' : ''}`}>{poem.body}</div>

      {(dateFormatted || poem.context || poem.sourceUrl) && (
        <footer class="editorial">
          <p>
            {dateFormatted && <span>Added {dateFormatted}.</span>}
            {poem.sourceUrl && <span> <a class="source-footer-link" href={poem.sourceUrl} target="_blank" rel="noopener noreferrer">View this poem at source.</a></span>}
            {poem.context && <span> {poem.context}</span>}
            {poem.editor?.initials && <span class="initials"> &mdash; {poem.editor.initials}</span>}
          </p>
        </footer>
      )}

      <p class="poem-id">{String(poem.number).padStart(5, '0')}</p>
    </article>
  </div>
</Layout>

<style>
  .poem-page {
    max-width: 740px;
  }

  h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: normal;
    font-size: 1.6rem;
    font-weight: 400;
    line-height: 1.4;
    margin-bottom: 0.3rem;
  }

  .author, .title-text {
    font-style: normal;
  }

  .title-text--untitled {
    color: #888;
  }

  .header-gap {
    margin-bottom: 3rem;
  }

  .source-line {
    margin-top: 0.3rem;
    font-size: 0.875rem;
    color: #aaa;
  }

  .source-italic { font-style: italic; }

  .source-footer-link {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: #ccc;
    text-underline-offset: 2px;
    text-decoration-thickness: 1px;
  }

  .source-footer-link:hover {
    color: #888;
  }

  .poem-body {
    font-size: 1.1rem;
    line-height: 1.75;
    white-space: pre-wrap;
  }

  .poem-body--long {
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .editorial {
    margin-top: 3.5rem;
    padding-top: 1.75rem;
    border-top: 1px solid #ddd8ce;
    font-size: 0.82rem;
    color: #aaa;
    line-height: 1.7;
  }

  .initials {
    color: #bbb;
  }

  .poem-id {
    margin-top: 3rem;
    text-align: center;
    font-family: monospace;
    font-size: 0.65rem;
    color: #bbb;
    letter-spacing: 0.05em;
  }
</style>
